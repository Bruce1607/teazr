# Canonical: /teaze (no trailing slash). ONLY redirect /teaze/ -> /teaze (never /teaze -> /teaze/)
# Query params preserved by Cloudflare. /teaze excluded from Functions so _redirects applies.
/teaze/   /teaze   301

# /teaze rewrite to teaze.html (avoids directory-style /teaze -> /teaze/ redirect)
/teaze    /teaze.html   200

# SPA fallback: MUST be last. Query params preserved.
/*        /index.html   200
