# HTML routes: no cache to avoid stale UI
/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/teaze
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/teaze*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/teaze.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# Hashed assets: immutable (Vite adds content hash to filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable
